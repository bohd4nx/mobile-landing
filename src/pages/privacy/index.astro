---
import Layout from "@layouts/Layout.astro";
import MarkdownLayout from "@shared/MarkdownLayout";
import "@styles/markdown-content.css";
import Breadcrumbs from "@ui/navigation/Breadcrumbs";
import { parseMarkdown } from "@utils/parseMarkdown";
import { appData } from "../../data";

type MarkdownModule = { rawContent(): string };
const privacyContent = Object.values(
	import.meta.glob<MarkdownModule>("./_privacy.md", { eager: true }),
)[0];
const rawContent = privacyContent.rawContent();
const htmlContent = String(await parseMarkdown(rawContent));
---

<Layout
	title={`Privacy Policy - ${appData.name}`}
	description="Learn how we collect, use, and protect your personal information. Our privacy policy outlines data handling practices, security measures, and your rights."
>
	<main class="pt-8 md:pt-12 px-4 md:px-6">
		<div class="max-w-375 mx-auto">
			<Breadcrumbs items={[{ label: "Privacy Policy" }]} client:load />
			<MarkdownLayout htmlContent={htmlContent} rawContent={rawContent} client:load />
		</div>
	</main>
</Layout>
