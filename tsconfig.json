{
	"extends": "astro/tsconfigs/strict",
	"compilerOptions": {
		"jsx": "react-jsx",
		"jsxImportSource": "react",
		"paths": {
			"@layouts/*": ["./src/layouts/*"],
			"@styles/*": ["./src/styles/*"],
			"@t/*": ["./src/types/*"],
			"@shared/*": ["./src/components/ui/shared/*"],
			"@ui/*": ["./src/components/ui/*"],
			"@screenshots/*": ["./src/components/screenshots/*"],
			"@reviews/*": ["./src/components/reviews/*"],
			"@features/*": ["./src/components/features/*"],
			"@faq/*": ["./src/components/faq/*"],
			"@hero/*": ["./src/components/hero/*"],
			"@footer/*": ["./src/components/footer/*"],
			"@social/*": ["./src/components/social/*"],
			"@utils/*": ["./src/utils/*"]
		}
	}
}
